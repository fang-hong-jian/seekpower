baseURL: "https://www.seekpower.top/"
languageCode: "zh-cn"
title: "年轻人，你渴望力量吗？"
theme: "textbook"

menu:
  #主导航
  main:
    - identifier: home
      name: 首页
      url: /
    - identifier: about-site
      name: 关于本站
      url: /about-site/
    - identifier: about-me
      name: 关于我
      url: /about-me/
  # 副导航
  second:
    - identifier: comment
      name: 留言
      url: /message/
    - identifier: login
      name: 登录
      url: /login/

disableKinds: ["taxonomy", "term"]
hasCJKLanguage: true

cleanDestinationDir: true #每次生成前清空public目录
enableEmoji: true #启用emoji表情
enableInlineShortcodes: true #启用内联短代码

markup: # 配置markdown解析器
  goldmark: # 配置Goldmark解析器
    extensions: # 启用扩展
      cjk: # CJK 扩展
        enable: true # 必须先启用 CJK 扩展
        eastAsianLineBreaks: true # 忽略东亚字符间的软换行
        eastAsianLineBreaksStyle: simple
        escapedSpace: false
    renderer: # 配置渲染器
      unsafe: true # 允许在markdown中使用html标签
