/* 主页大标题和图片 */
.home-context {
	display: flex;
	flex-direction: row;
	justify-content: space-around;
	align-items: center;
	padding-left: 150px;
	padding-right: 150px;
	padding-top: 100px;
	padding-bottom: 10px;
	border-bottom-style: solid;
	border-bottom-width: 1px;
	border-bottom-color: var(--border-color);
}

/* 主页标题字 */
.young {
	width: 600px;
	flex: 1, 1, 500px;
	font-size: 40px;
}

/* 主页大图 */
.home-right {
	width: 800px;
	flex: 1, 1, 500px;
}

/* 书籍阵列总框 */
div.display {
	display: flex;
	flex-direction: column;
	align-items: flex-start;
	justify-content: flex-start;
	min-height: 500px;
}

/* 科目栏 */
.subjects {
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: flex-start;
	padding-left: 40px;
	padding-right: 30px;
	border-top-style: solid;
	border-top-width: 1px;
	border-top-color: var(--border-color);
	border-bottom-style: solid;
	border-bottom-width: 1px;
	border-bottom-color: var(--border-color);
}

/* 单个科目导航按钮 */
.subject {
	background: none;
	border: none;
	display: flex;
	align-items: center;
	height: 60px;
	padding: 15px;
	padding-left: 15px;
	font-family: var(--font-sans);
	font-size: 22px;
	font-weight: 600;
	margin: 8px;
}


/* 激活的科目导航按钮 */
.subject.active {
	background-color: var(--active-bgcolor);
	border-radius: 16px;
	color: darkcyan;
}

/* 悬停时科目导航按钮 */
.subject:hover {
	background-color: var(--active-bgcolor);
	border-radius: 16px;
	color: darkcyan;
	/* transform: scale(0.98); */
}

/* 点击时科目导航按钮 */
.subject:active {
	transform: scale(0.98);
}

/* 陈列栏 */

.books {
	display: flex;
	flex-direction: row;
	justify-content: flex-start;
	flex-wrap: wrap;
	align-items: center;
	padding-left: 40px;
}

.allbooks {
	display: none;
}

.allbooks.active {
	display: flex;
	flex-direction: column;
	justify-content: space-between;
	color: inherit;
	text-decoration: none;
	width: 280px;
	min-height: 300px;
	height: auto;
	border-style: solid;
	border-width: 1px;
	border-radius: 20px;
	border-color: var(--border-color);
	margin: 20px;
	margin-top: 30px;
	padding: 28px 24px 22px;
	background-color: white;
}

.allbooks:hover {
	transform: translateY(-4px);
	box-shadow: 0 5px 8px rgba(0, 0, 0, 0.1);
}

.book-info {
	margin: 0px;
	padding: 0px;
	height: 260px;
	border-bottom-style: solid;
	border-bottom-width: 1px;
	border-bottom-color: var(--border-color);
}

.bookname {
	color: black;
	margin-bottom: 8px;
	font-size: 23.2px;
	font-weight: 700;
	line-height: 1.3;
}

.book-subtitle {
	font-size: 16px;
	font-weight: 500;
	line-height: 1.4;
	border-left: 3px solid #3498db;
	padding-left: 12px;
	margin-bottom: 18px;
}

/* 书籍卡中的描述 */
.book-describe {
	height: 120px;
	font-size: 14px;
	margin-top: 14px;
	margin-bottom: 14px;
}

/* 书籍卡的元数据 */
.book-meta {
	display: flex;
	height: 25px;
	justify-content: space-between;
	align-items: center;
}

/* 标签样式 */
.finish {
	display: inline-block;
	padding: 4px 8px;
	margin: 4px 8px 4px 8px;
	background-color: var(--tag-bacolor);
	color: #333;
	border-radius: 20px;
	font-size: 14px;
	text-decoration: none;
	transition: all 0.3s ease;
}
