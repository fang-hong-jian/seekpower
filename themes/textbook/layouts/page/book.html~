{{ define "title" }}
{{ .Params.bookname }}
{{ end }}

{{/* 书籍主页 */}}
{{define "main"}}
<link rel="stylesheet" href={{"css/style-book.css"| relURL}} />
<script src={{"js/book.js"| relURL}}></script>
{{/* 侧边栏区 */}}
{{/* 目录 */}}
<div class="tocs">
	{{/* 书名 */}}
	<p class="bookname">{{ .Params.bookname }}</p>
	<div class="toc-header">
		<div class="toc-title">目录</div>
		<div class="book-meta">
			<p><span>共 {{ len .Params.chapters}}章</span><span>作者:{{ .Page.Params.author}}</span></p>
		</div>
	</div>

	<ul class="toc-list">
		<!-- 书籍简介链接 -->
		<li class="toc-item">
			<a href="#book-intro" class="toc-link" data-url="{{ .Permalink }}" data-type="book">
				前言
			</a>
		</li>

		<!-- 各章节链接 -->
		{{ $page := . }}
		{{ range .Params.chapters }}
		{{ $u := . }}
		{{ with $page.GetPage . }}
		<li class="toc-item">
			<a href="{{ relref . $u }}" class="toc-link" data-type="chapter">
				{{/* 遍历文件标题 */}}
				{{ .Title }}
			</a>
		</li>
		{{ end }}
		{{ end }}
	</ul>
</div>

{{/* 正文区 */}}
<article class="book-content">
	<div id="book-intro">
		<div class="book-description">
			{{ .Content }}
		</div>
	</div>

	{{/* 动态加载容器 */}}
	<div id="chapter-container"></div>
</article>
{{end}}
