<!DOCTYPE html>
<html lang={{ .Site.LanguageCode | default "zh-cn" }}>

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	{{/* 标题 */}}
	<title>{{ block "title" . }}{{ end }}</title>
	<link rel="stylesheet" href={{ "css/style-baseof.css" | relURL}} />
	<link rel="shortcut icon" href={{ "icons/logo.png" | relURL}} type="image/x-icon" />
	<script>
		MathJax = {
			tex: {
				inlineMath: [['$', '$'], ['\\(', '\\)']],  // 行内公式分隔符
				displayMath: [['$$', '$$'], ['\\[', '\\]']]  // 行间公式分隔符
			},
			svg: {
				fontCache: 'global'
			}
		};
	</script>
	<script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>
</head>

<body>
	<!-- 导入页头 -->
	{{ partial "header.html" . }}

	<!-- 主要内容区域，由其他模板填充 -->
	<main>
		{{ block "main" . }}{{ end }}
	</main>

	<!-- 导入页脚 -->
	{{ partial "footer.html" . }}
</body>

</html>
