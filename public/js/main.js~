// 将代码放在DOMContentLoaded事件中，确保DOM加载完成后再执行
globalThis.addEventListener('DOMContentLoaded', () => {
	// 获取所有科目导航按钮对象
	const subjectButtons = document.querySelectorAll('.subject');

	// 为每个按钮添加点击事件
	for (const button of subjectButtons) {
		button.addEventListener('click', function () {
			// 点击执行以下内容
			// 获取被点击的按钮的id
			const buttonId = this.id;

			// 移除所有按钮的active类
			for (const btn of subjectButtons) {
				btn.classList.remove('active');
			}

			// 给当前点击的按钮添加active类
			this.classList.add('active');

			// 取消所有书籍列表的active类
			for (const bookList of document.querySelectorAll('.allbooks')) {
				bookList.classList.remove('active');
			}

			// 根据按钮id构建对应的书籍列表id
			// 例如：按钮id="math" -> 书籍列表id="mathbooks"
			const bookListClass = '.' + buttonId + 'books';
			const targetBookList = document.querySelectorAll(bookListClass);
			for (const book of targetBookList) {
			book.classList.add('active');
			}
		});
	}
});
