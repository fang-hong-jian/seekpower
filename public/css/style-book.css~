header#homeheader {
	display: none;
}

/* 书籍主页模板 */
main {
	display: flex;
	flex-direction: column;
	margin-top: 0px;
	min-height: 90vh;
}

/*页面路径导航样式*/
.page-path {
	display: flex;
	padding-left: 32px;
	padding-bottom: 15px;
	margin-top: 15px;
	font-size: 18px;
	font-weight: 500;
}

.path {
	border-radius: 3px;
	padding-left: 5px;
	padding-right: 5px;
	color: inherit;
	text-decoration: none;
}

.path:hover {
	background-color: var(--active-bgcolor);
}

.home-page-path {
	color: darkred;
}

.book-page-path {
	color: darkcyan;
}

.chapter-page-path {
	color: darkgreen;
}

/*前面加个箭头*/
.arrow::before {
	content: ">";
	margin-left: 5px;
	margin-right: 5px;
}

/*书籍内容*/
main>div {
	display: flex;
}


/* 书籍模板左侧边栏 */
div.tocs {
	display: flex;
	flex-direction: column;
	width: 320px;
	border-right: 1px solid #e0e0e0;
	padding-top: 0px;
	/* y向溢出 */
	overflow-y: auto;
	/* 收缩 */
	flex-shrink: 0;
}


/*书名*/
div.bookname {
	font-size: 24px;
	font-weight: 700;
	padding-left: 32px;
	padding-bottom: 5px;
}

/* 目录区 */
.toc-header {
	padding-left: 32px;
	padding-right: 32px;
	padding-top: 10px;
	border-bottom: 1px solid #e0e0e0;
	border-top: 1px solid #e0e0e0;
}

.book-meta>div {
	margin: 0px;
	padding-bottom: 8px;
}

.book-meta>p>span {
	font-family: "Inter";
	font-weight: 400;
	margin: 0px;
	padding-right: 8px;
}

/* 目录标头 */
.toc-title {
	font-size: 24px;
	font-weight: 600;
}

.toc-list {
	list-style: none;
}

.toc-item {
	margin-bottom: 8px;
}

.toc-link {
	display: block;
	padding-top: 10px;
	padding-bottom: 10px;
	text-decoration: none;
	color: #2c3e50;
	border-radius: 6px;
	transition: all 0.2s;
}

.toc-link:hover {
	background: #e9ecef;
	font-weight: 700;
}

.toc-link.active {
	background: #e9ecef;
}

.section-2 {
	font-size: 16px;
	margin-left: 5px;
}

.section-3 {
	padding-left: 5px;
	margin-left: 5px;
}

/* 正文区 */
.book-content {
	flex: 1;
	margin-left: 25px;
	overflow-y: auto;
}

.book-title {
	font-size: 32px;
	margin-bottom: 20px;
	color: #2c3e50;
}

.book-description {
	color: #2c3e50;
	margin-bottom: 30px;
	font-size: 18px;
	line-height: 1.8;
}

.chapter-content {
	margin-top: 100px;
	max-width: 800px;
}

.chapter-title {
	font-size: 28px;
	margin-bottom: 20px;
	color: #333;
	padding-bottom: 10px;
	border-bottom: 2px solid #f0f0f0;
}

.chapter-body {
	font-size: 18px;
	line-height: 1.8;
}

.chapter-body h2 {
	font-size: 24px;
	margin: 30px 0 15px;
	color: #444;
}

.chapter-body h3 {
	font-size: 20px;
	margin: 25px 0 12px;
	color: #555;
}

.chapter-body p {
	margin-bottom: 20px;
}

.chapter-body code {
	background: #f5f5f5;
	padding: 2px 6px;
	border-radius: 4px;
	font-family:
		"SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
}

.chapter-body pre {
	background: #f8f9fa;
	padding: 20px;
	border-radius: 8px;
	overflow-x: auto;
	margin: 20px 0;
	border-left: 4px solid #007bff;
}
